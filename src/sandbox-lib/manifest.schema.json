{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gulps.example.com/manifest.schema.json",
  "title": "GULPS Activity Manifest",
  "description": "Manifest for a GULPS learning activity, declaring capabilities and values.",
  "type": "object",
  "required": ["name", "client"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique identifier for the activity."
    },
    "client": {
      "type": "string",
      "description": "Path to the client-side JavaScript file, relative to activity directory."
    },
    "server": {
      "type": "string",
      "description": "Path to the server-side WASM file, relative to activity directory."
    },
    "capabilities": {
      "type": "object",
      "description": "Declared capabilities that the sandbox can use.",
      "additionalProperties": false,
      "properties": {
        "http": {
          "description": "HTTP request capability.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allowed_hosts": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Allowed hostnames. Empty array allows all hosts."
            }
          }
        },
        "ai": {
          "description": "AI model access capability.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "models": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Allowed model names. Empty array allows all models."
            }
          }
        }
      }
    },
    "values": {
      "type": "object",
      "description": "Declared activity values with type, scope, and access control.",
      "additionalProperties": {
        "$ref": "#/$defs/valueDefinition"
      }
    }
  },
  "$defs": {
    "valueDefinition": {
      "type": "object",
      "required": ["type", "scope", "access"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["integer", "float", "string", "boolean"],
          "description": "Data type of the value."
        },
        "scope": {
          "type": "string",
          "enum": ["unit", "user,unit"],
          "description": "Scope of the value. 'unit' is shared across users, 'user,unit' is per-user."
        },
        "access": {
          "type": "string",
          "enum": ["user", "unit", "course", "platform"],
          "description": "Minimum access level required to read this value."
        },
        "default": {
          "description": "Default value (must match declared type)."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "integer" } } },
          "then": { "properties": { "default": { "type": "integer" } } }
        },
        {
          "if": { "properties": { "type": { "const": "float" } } },
          "then": { "properties": { "default": { "type": "number" } } }
        },
        {
          "if": { "properties": { "type": { "const": "string" } } },
          "then": { "properties": { "default": { "type": "string" } } }
        },
        {
          "if": { "properties": { "type": { "const": "boolean" } } },
          "then": { "properties": { "default": { "type": "boolean" } } }
        }
      ]
    }
  }
}
