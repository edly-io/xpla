{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xpla.example.com/manifest.schema.json",
  "title": "xPLA Activity Manifest",
  "description": "Manifest for a xPLA learning activity, declaring capabilities and fields.",
  "type": "object",
  "required": ["name", "client"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique identifier for the activity."
    },
    "client": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\.\\.).+$",
      "description": "Path to the client-side JavaScript file, relative to activity directory."
    },
    "server": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\.\\.).+$",
      "description": "Path to the server-side WASM file, relative to activity directory."
    },
    "capabilities": {
      "type": "object",
      "description": "Declared capabilities that the sandbox can use.",
      "additionalProperties": false,
      "properties": {
        "http": {
          "description": "HTTP request capability.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allowed_hosts": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Allowed hostnames. Empty array allows all hosts."
            }
          }
        },
        "ai": {
          "description": "AI model access capability.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "models": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Allowed model names. Empty array allows all models."
            }
          }
        }
      }
    },
    "fields": {
      "type": "object",
      "description": "Declared activity fields with type and scope.",
      "additionalProperties": {
        "$ref": "#/$defs/fieldDefinition"
      }
    },
    "actions": {
      "type": "object",
      "description": "Actions the client can send to the server sandbox.",
      "additionalProperties": { "$ref": "#/$defs/typeSchema" }
    },
    "events": {
      "type": "object",
      "description": "Events the server sandbox can emit to the client.",
      "additionalProperties": { "$ref": "#/$defs/typeSchema" }
    },
    "streams": {
      "type": "object",
      "description": "Declared data streams (append-only, ordered collections).",
      "additionalProperties": {
        "$ref": "#/$defs/streamDefinition"
      }
    },
    "static": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(?!/)(?!.*\\.\\.).+$"
      },
      "description": "Static file paths that can be served as assets. Must be relative (no leading '/') and cannot contain '..'."
    }
  },
  "$defs": {
    "fieldDefinition": {
      "type": "object",
      "required": ["type", "scope"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["integer", "number", "string", "boolean", "array", "object"],
          "description": "Data type of the field. Uses JSON Schema type names."
        },
        "items": {
          "$ref": "#/$defs/typeSchema",
          "description": "Schema for array items. Required when type is 'array'."
        },
        "properties": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/typeSchema" },
          "description": "Schema for object properties. Used when type is 'object'."
        },
        "scope": {
          "type": "string",
          "enum": ["activity", "course", "platform", "user,activity", "user,course", "user,platform"],
          "description": "Scope of the field. Scopes without 'user' are shared across users. 'activity' scopes are per-activity-instance, 'course' scopes are per-course, 'platform' scopes are global."
        },
        "default": {
          "description": "Default value (must match declared type)."
        }
      }
    },
    "streamDefinition": {
      "type": "object",
      "required": ["items", "scope"],
      "additionalProperties": false,
      "properties": {
        "items": {
          "$ref": "#/$defs/typeSchema",
          "description": "Schema for each entry in the stream."
        },
        "scope": {
          "type": "string",
          "enum": ["activity", "course", "platform", "user,activity", "user,course", "user,platform"],
          "description": "Scope of the stream."
        }
      }
    },
    "typeSchema": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["integer", "number", "string", "boolean", "array", "object"],
          "description": "Data type."
        },
        "items": {
          "$ref": "#/$defs/typeSchema",
          "description": "Schema for array items."
        },
        "properties": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/typeSchema" },
          "description": "Schema for object properties."
        }
      }
    }
  }
}
