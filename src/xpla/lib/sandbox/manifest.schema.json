{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xpla.example.com/manifest.schema.json",
  "title": "xPLA Activity Manifest",
  "description": "Manifest for a xPLA learning activity, declaring capabilities and fields.",
  "type": "object",
  "required": ["name", "ui"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique identifier for the activity."
    },
    "ui": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\.\\.).+$",
      "description": "Path to the UI script, relative to activity directory."
    },
    "sandbox": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\.\\.).+$",
      "description": "Path to the sandboxed WASM component, relative to activity directory."
    },
    "capabilities": {
      "type": "object",
      "description": "Declared capabilities that the sandbox can use. Each capability maps to a host interface the executor will wire up. Additional properties are allowed so downstream apps can declare their own interfaces.",
      "properties": {
        "http": {
          "description": "HTTP request capability.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allowed_hosts": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Allowed hostnames. Empty array allows all hosts."
            }
          }
        },
        "storage": {
          "description": "Named file storage buckets with scope declarations.",
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/storageDefinition"
          }
        },
        "grading": {
          "description": "Grading/reporting capability. Empty object marker — declares the sandbox imports the grading interface (submit-grade, report-*).",
          "type": "object",
          "additionalProperties": false
        }
      }
    },
    "fields": {
      "type": "object",
      "description": "Declared activity fields with type and scope.",
      "additionalProperties": {
        "$ref": "#/$defs/fieldDefinition"
      }
    },
    "actions": {
      "type": "object",
      "description": "Actions the client can send to the server sandbox.",
      "additionalProperties": { "$ref": "#/$defs/typeSchema" }
    },
    "events": {
      "type": "object",
      "description": "Events the server sandbox can emit to the client.",
      "additionalProperties": { "$ref": "#/$defs/typeSchema" }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(?!/)(?!.*\\.\\.).+$"
      },
      "description": "Static file paths that can be served as assets. Must be relative (no leading '/') and cannot contain '..'."
    }
  },
  "$defs": {
    "storageDefinition": {
      "type": "object",
      "required": ["scope"],
      "additionalProperties": false,
      "properties": {
        "scope": {
          "type": "string",
          "enum": ["activity", "course", "global", "user,activity", "user,course", "user,global"],
          "description": "Scope of the storage bucket. Determines the context dimensions used to partition files."
        }
      }
    },
    "fieldBase": {
      "type": "object",
      "required": ["scope"],
      "properties": {
        "scope": {
          "type": "string",
          "enum": ["activity", "course", "global", "user,activity", "user,course", "user,global"],
          "description": "Scope of the field. Scopes without 'user' are shared across users. 'activity' scopes are per-activity-instance, 'course' scopes are per-course, 'global' scopes are for the whole platform."
        },
        "default": {
          "description": "Default value (must match declared type)."
        }
      }
    },
    "integerField": {
      "unevaluatedProperties": false,
      "allOf": [{ "$ref": "#/$defs/integerType" }, { "$ref": "#/$defs/fieldBase" }]
    },
    "numberField": {
      "unevaluatedProperties": false,
      "allOf": [{ "$ref": "#/$defs/numberType" }, { "$ref": "#/$defs/fieldBase" }]
    },
    "stringField": {
      "unevaluatedProperties": false,
      "allOf": [{ "$ref": "#/$defs/stringType" }, { "$ref": "#/$defs/fieldBase" }]
    },
    "booleanField": {
      "unevaluatedProperties": false,
      "allOf": [{ "$ref": "#/$defs/booleanType" }, { "$ref": "#/$defs/fieldBase" }]
    },
    "arrayField": {
      "unevaluatedProperties": false,
      "allOf": [{ "$ref": "#/$defs/arrayType" }, { "$ref": "#/$defs/fieldBase" }]
    },
    "objectField": {
      "unevaluatedProperties": false,
      "allOf": [{ "$ref": "#/$defs/objectType" }, { "$ref": "#/$defs/fieldBase" }]
    },
    "logField": {
      "unevaluatedProperties": false,
      "allOf": [{ "$ref": "#/$defs/logType" }, { "$ref": "#/$defs/fieldBase" }]
    },
    "fieldDefinition": {
      "oneOf": [
        { "$ref": "#/$defs/integerField" },
        { "$ref": "#/$defs/numberField" },
        { "$ref": "#/$defs/stringField" },
        { "$ref": "#/$defs/booleanField" },
        { "$ref": "#/$defs/arrayField" },
        { "$ref": "#/$defs/objectField" },
        { "$ref": "#/$defs/logField" }
      ]
    },
    "integerType": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "const": "integer" }
      }
    },
    "numberType": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "const": "number" }
      }
    },
    "stringType": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "const": "string" }
      }
    },
    "booleanType": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "const": "boolean" }
      }
    },
    "arrayType": {
      "type": "object",
      "required": ["type", "items"],
      "properties": {
        "type": { "type": "string", "const": "array" },
        "items": { "$ref": "#/$defs/typeSchema" }
      }
    },
    "objectType": {
      "type": "object",
      "required": ["type", "properties"],
      "properties": {
        "type": { "type": "string", "const": "object" },
        "properties": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/typeSchema" }
        }
      }
    },
    "logType": {
      "type": "object",
      "required": ["type", "items"],
      "properties": {
        "type": { "type": "string", "const": "log" },
        "items": { "$ref": "#/$defs/typeSchema" }
      }
    },
    "typeSchema": {
      "oneOf": [
        { "$ref": "#/$defs/integerType" },
        { "$ref": "#/$defs/numberType" },
        { "$ref": "#/$defs/stringType" },
        { "$ref": "#/$defs/booleanType" },
        { "$ref": "#/$defs/arrayType" },
        { "$ref": "#/$defs/objectType" }
      ]
    }
  }
}
