{
  "name": "python",
  "client": "client.bundle.js",
  "server": "server.wasm",
  "capabilities": {},
  "fields": {
    "instructions": {
      "type": "string",
      "scope": "activity",
      "default": ""
    },
    "test_code": {
      "type": "string",
      "scope": "activity",
      "default": ""
    },
    "starter_code": {
      "type": "string",
      "scope": "activity",
      "default": ""
    },
    "user_code": {
      "type": "string",
      "scope": "user,activity",
      "default": ""
    }
  },
  "actions": {
    "config.save": {
      "type": "object",
      "properties": {
        "instructions": {
          "type": "string"
        },
        "test_code": {
          "type": "string"
        },
        "starter_code": {
          "type": "string"
        }
      }
    },
    "code.run": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        }
      }
    },
    "code.check": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        }
      }
    }
  },
  "events": {
    "fields.change.user_code": { "type": "string" },
    "fields.change.instructions": { "type": "string" },
    "fields.change.test_code": { "type": "string" },
    "fields.change.starter_code": { "type": "string" }
  },
  "assets": [
    "assets/pyodide/pyodide.mjs",
    "assets/pyodide/pyodide-lock.json",
    "assets/pyodide/pyodide.asm.wasm",
    "assets/pyodide/pyodide.asm.js",
    "assets/pyodide/python_stdlib.zip"
  ]
}
