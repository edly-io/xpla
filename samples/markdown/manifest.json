{
  "name": "markdown",
  "client": "client.js",
  "server": "server.wasm",
  "capabilities": {},
  "values": {
    "markdown_content": { "type": "string", "scope": "activity", "default": "" },
    "header_start_level": { "type": "integer", "scope": "activity", "default": 2 },
    "rendered_html": { "type": "string", "scope": "activity", "default": "" }
  },
  "actions": {
    "config.save": {
      "type": "object",
      "properties": {
        "markdown_content": { "type": "string" }
      }
    }
  },
  "events": {
    "values.change.markdown_content": { "type": "string" },
    "values.change.rendered_html": { "type": "string" }
  }
}
