{
  "name": "markdown",
  "fields": {
    "markdown_content": {
      "type": "string",
      "scope": "activity",
      "default": ""
    },
    "header_start_level": {
      "type": "integer",
      "scope": "activity",
      "default": 2
    },
    "rendered_html": {
      "type": "string",
      "scope": "activity",
      "default": ""
    }
  },
  "actions": {
    "config.save": {
      "type": "object",
      "properties": {
        "markdown_content": {
          "type": "string"
        }
      }
    }
  },
  "events": {
    "fields.change.markdown_content": {
      "type": "string"
    },
    "fields.change.rendered_html": {
      "type": "string"
    }
  },
  "ui": "ui.js",
  "sandbox": "sandbox.wasm"
}
