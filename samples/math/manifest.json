{
  "name": "math",
  "client": "client.js",
  "server": "server.component.wasm",
    "fields": {
    "correct_answers": {
      "type": "integer",
      "scope": "user,activity",
      "default": 0
    },
    "wrong_answers": {
      "type": "integer",
      "scope": "user,activity",
      "default": 0
    }
  },
  "actions": {
    "answer.submit": {
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "answer": { "type": "string" }
      }
    }
  },
  "events": {
    "answer.result": {
      "type": "object",
      "properties": {
        "correct": { "type": "boolean" },
        "feedback": { "type": "string" }
      }
    },
    "fields.change.correct_answers": { "type": "integer" },
    "fields.change.wrong_answers": { "type": "integer" }
  }
}
