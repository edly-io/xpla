{
  "name": "math",
  "client": "client.js",
  "server": "server.wasm",
  "capabilities": {},
  "values": {
    "correct_answers": {
      "type": "integer",
      "scope": "user,unit",
      "access": "user",
      "default": 0
    },
    "wrong_answers": {
      "type": "integer",
      "scope": "user,unit",
      "access": "user",
      "default": 0
    }
  },
  "actions": {
    "answer.submit": {
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "answer": { "type": "string" }
      }
    }
  },
  "events": {
    "answer.result": {
      "type": "object",
      "properties": {
        "correct": { "type": "boolean" },
        "feedback": { "type": "string" }
      }
    }
  }
}