{
  "name": "collab-editor",
  "client": "client.bundle.js",
  "server": "server.component.wasm",
  "capabilities": {},
  "fields": {
    "doc_state": {
      "type": "string",
      "scope": "activity",
      "default": ""
    },
    "content": {
      "type": "string",
      "scope": "activity",
      "default": ""
    },
    "render_markdown": {
      "type": "integer",
      "scope": "activity",
      "default": 0
    }
  },
  "actions": {
    "config.save": {
      "type": "object",
      "properties": {
        "render_markdown": {"type": "integer"}
      }
    },
    "doc.update": {
      "type": "object",
      "properties": {
        "data": {"type": "string"}
      }
    },
    "cursor.move": {
      "type": "object",
      "properties": {
        "index": {"type": "integer"},
        "length": {"type": "integer"}
      }
    }
  },
  "events": {
    "fields.change.render_markdown": { "type": "integer" },
    "doc.update": {
      "type": "object",
      "properties": {
        "data": {"type": "string"},
        "user": {"type": "string"}
      }
    },
    "cursor.move": {
      "type": "object",
      "properties": {
        "user": {"type": "string"},
        "index": {"type": "integer"},
        "length": {"type": "integer"}
      }
    }
  }
}
