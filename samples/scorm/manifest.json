{
  "name": "scorm",
  "capabilities": {
    "storage": {
      "content": {
        "scope": "activity"
      }
    }
  },
  "fields": {
    "entry_point": {
      "type": "string",
      "scope": "activity",
      "default": ""
    }
  },
  "actions": {
    "scorm.upload": {
      "type": "object",
      "properties": {
        "data": {
          "type": "string"
        }
      },
      "required": [
        "data"
      ]
    }
  },
  "events": {
    "scorm.ready": {
      "type": "string"
    }
  },
  "ui": "ui.js",
  "sandbox": "sandbox.wasm"
}
