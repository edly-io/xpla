{
  "name": "image",
  "capabilities": {
    "storage": {
      "media": {
        "scope": "activity"
      }
    }
  },
  "fields": {
    "image_filename": {
      "type": "string",
      "scope": "activity",
      "default": ""
    }
  },
  "actions": {
    "image.upload": {
      "type": "object",
      "properties": {
        "data": {
          "type": "string"
        }
      },
      "required": [
        "data"
      ]
    }
  },
  "events": {
    "image.changed": {
      "type": "string"
    }
  },
  "ui": "ui.js",
  "sandbox": "sandbox.wasm"
}
